#!/usr/bin/env python3

import os
import subprocess
import sys


FREEZE_DOC = "/home/agent/agents/core/artifacts/architecture/latest-retrieval-execution-canonical-v2-freeze.md"
RUN_TARGET = "/home/agent/bin/run-retrieval-execution-v1-canonical-v2"
REGRESS_TARGET = "/home/agent/bin/run-retrieval-execution-canonical-v2-regress"
FULL_REGRESS_TARGET = "/home/agent/bin/run-retrieval-execution-canonical-v2-full-regress"


def emit(line: str) -> None:
    print(line, flush=True)


def stream_command(cmd: list[str]) -> int:
    proc = subprocess.Popen(cmd, stdout=sys.stdout, stderr=sys.stderr)
    return proc.wait()


def usage() -> int:
    emit("USAGE=run-retrieval-execution-default [status|run|regress|full-regress] [args...]")
    emit("DEFAULT_ENTRYPOINT=run-retrieval-execution-default")
    emit(f"RUN_TARGET={RUN_TARGET}")
    emit(f"REGRESS_TARGET={REGRESS_TARGET}")
    emit(f"FULL_REGRESS_TARGET={FULL_REGRESS_TARGET}")
    emit(f"FREEZE_DOC={FREEZE_DOC}")
    return 0


def main() -> int:
    raw_args = sys.argv[1:]

    if raw_args and raw_args[0] in {"-h", "--help", "help"}:
        return usage()

    if not raw_args:
        mode = "run"
        passthrough = []
    else:
        mode = raw_args[0]
        passthrough = raw_args[1:]

    emit("DEFAULT_ENTRYPOINT=run-retrieval-execution-default")

    if mode == "status":
        emit("DEFAULT_MODE=canonical-v2")
        emit(f"RUN_TARGET={RUN_TARGET}")
        emit(f"REGRESS_TARGET={REGRESS_TARGET}")
        emit(f"FULL_REGRESS_TARGET={FULL_REGRESS_TARGET}")
        emit(f"FREEZE_DOC={FREEZE_DOC}")
        emit("RULE=Downstream execution workflows should use this wrapper instead of calling raw run-retrieval-execution-v1 directly.")
        emit("DEFAULT_ENTRYPOINT_STATUS=ok")
        return 0

    if mode == "run":
        target = RUN_TARGET
        emit("DEFAULT_MODE=run")
    elif mode == "regress":
        target = REGRESS_TARGET
        emit("DEFAULT_MODE=regress")
    elif mode == "full-regress":
        target = FULL_REGRESS_TARGET
        emit("DEFAULT_MODE=full-regress")
    else:
        emit(f"ERROR=unsupported_mode:{mode}")
        emit("DEFAULT_ENTRYPOINT_STATUS=failed")
        return 2

    if not os.path.exists(target):
        emit(f"ERROR=missing_target:{target}")
        emit("DEFAULT_ENTRYPOINT_STATUS=failed")
        return 2

    if not os.access(target, os.X_OK):
        emit(f"ERROR=target_not_executable:{target}")
        emit("DEFAULT_ENTRYPOINT_STATUS=failed")
        return 2

    cmd = [target, *passthrough]

    emit(f"TARGET={target}")
    emit(f"FREEZE_DOC={FREEZE_DOC}")
    emit(f"CMD={' '.join(cmd)}")

    rc = stream_command(cmd)

    if rc != 0:
        emit(f"Default entrypoint target failed with exit code {rc}")
        return rc

    emit("DEFAULT_ENTRYPOINT_STATUS=ok")
    return 0


if __name__ == "__main__":
    sys.exit(main())