#!/usr/bin/env python3
from __future__ import annotations

import argparse
import re
import subprocess
import sys
from pathlib import Path


RUNNER = Path("/home/agent/bin/run-retrieval-execution-v1")
COMPOSER = Path("/home/agent/bin/refine-retrieval-answer-composition-v2")


def eprint(*args) -> None:
    print(*args, file=sys.stderr)


def ensure_executable(path: Path, label: str) -> None:
    if not path.exists():
        raise FileNotFoundError(f"Missing {label}: {path}")


def stream_command(cmd: list[str]) -> tuple[int, str]:
    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    )
    collected: list[str] = []

    assert proc.stdout is not None
    for line in proc.stdout:
        print(line, end="")
        collected.append(line)

    rc = proc.wait()
    return rc, "".join(collected)


def normalize_value(value: str) -> str:
    return value.strip().strip("`").strip().strip('"').strip("'")


def extract_artifact_dir(output: str) -> Path | None:
    patterns = [
        re.compile(r"^OUTDIR=(.+)$", re.MULTILINE),
        re.compile(r"^ARTIFACT_DIR=(.+)$", re.MULTILINE),
        re.compile(r"^ARTIFACT=(.+)$", re.MULTILINE),
    ]
    for pattern in patterns:
        match = pattern.search(output)
        if match:
            return Path(normalize_value(match.group(1))).resolve()
    return None


def resolve_artifact_dir(value: str) -> Path:
    path = Path(value)
    if path.is_file():
        path = path.parent
    return path.resolve()


def run_composer(artifact_dir: Path) -> int:
    cmd = [str(COMPOSER), str(artifact_dir)]
    rc, _output = stream_command(cmd)
    if rc != 0:
        eprint(f"Composer failed for artifact: {artifact_dir}")
        return rc

    composed = artifact_dir / "ANSWER.composed-v2.md"
    meta = artifact_dir / "ANSWER.composed-v2.meta.json"

    print(f"COMPOSED_OUTPUT={composed}")
    print(f"COMPOSED_META={meta}")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Run retrieval execution v1 and immediately apply Answer Composition Quality v2 post-compose."
    )
    parser.add_argument(
        "--artifact-dir",
        help="Compose an existing retrieval-execution artifact directly instead of running the base runner.",
    )
    args, runner_args = parser.parse_known_args()
    if runner_args and runner_args[0] == "--":
        runner_args = runner_args[1:]

    ensure_executable(RUNNER, "base runner")
    ensure_executable(COMPOSER, "composition refiner")

    if args.artifact_dir:
        artifact_dir = resolve_artifact_dir(args.artifact_dir)
        answer_path = artifact_dir / "ANSWER.md"
        if not answer_path.exists():
            eprint(f"Missing source answer: {answer_path}")
            return 1

        print("MODE=artifact-only")
        print(f"ARTIFACT_DIR={artifact_dir}")
        return run_composer(artifact_dir)

    print("MODE=runner-plus-compose")
    runner_cmd = [str(RUNNER), *runner_args]
    print("RUNNER_CMD=" + " ".join(runner_cmd))

    rc, output = stream_command(runner_cmd)
    if rc != 0:
        eprint(f"Base runner failed with exit code {rc}")
        return rc

    artifact_dir = extract_artifact_dir(output)
    if artifact_dir is None:
        eprint("Could not detect artifact directory from runner output. Expected OUTDIR=...")
        return 2

    answer_path = artifact_dir / "ANSWER.md"
    if not answer_path.exists():
        eprint(f"Runner finished, but source answer is missing: {answer_path}")
        return 3

    print(f"ARTIFACT_DIR={artifact_dir}")
    return run_composer(artifact_dir)


if __name__ == "__main__":
    sys.exit(main())
