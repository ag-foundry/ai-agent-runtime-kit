def chunk_lines(text: str, max_lines: int = 6) -> List[Tuple[str, str]]:
    lines = text.splitlines()
    chunks: List[Tuple[str, str]] = []
    current: List[str] = []
    start = 1

    for idx, line in enumerate(lines, start=1):
        stripped = line.rstrip()
        if stripped == "":
            if current:
                end = idx - 1
                snippet = "\n".join(current).strip()
                if snippet:
                    chunks.append((f"L{start}-L{end}", snippet))
                current = []
            start = idx + 1
            continue

        if not current:
            start = idx

        current.append(stripped)

        if len(current) >= max_lines:
            end = idx
            snippet = "\n".join(current).strip()
            if snippet:
                chunks.append((f"L{start}-L{end}", snippet))
            current = []
            start = idx + 1

    if current:
        end = len(lines)
        snippet = "\n".join(current).strip()
        if snippet:
            chunks.append((f"L{start}-L{end}", snippet))

    return chunks


def query_terms(query: str) -> List[str]:
    words = re.findall(r"[A-Za-zА-Яа-я0-9_-]{3,}", query.lower())
    stop = {
        "what", "which", "after", "before", "with", "from", "that",
        "this", "there", "have", "been", "into", "layer", "step",
        "confirmed", "next", "chain", "после", "какой", "какая",
        "какое", "шаг", "следующий", "подтвержденный", "подтверждённый",
    }
    return [w for w in words if w not in stop][:12]


def is_current_status_query(query: str) -> bool:
    q = " ".join(query.lower().split())
    if not q:
        return False

    explicit_phrases = (
        "current grounded project status",
        "current grounded status",
        "current project status",
        "current operational status",
        "current grounded operational status",
        "current project state",
        "overall state",
        "current state",
    )

    if any(phrase in q for phrase in explicit_phrases):
        return True

    return "current" in q and ("status" in q or "state" in q)


def query_intent(query: str) -> str:
    q = " ".join(query.lower().split())

    if is_current_status_query(q) or "текущее состояние проекта" in q or "состояние проекта" in q:
        return "project_state"

    if (
        "next confirmed step" in q
        or "next step" in q
        or "следующий шаг" in q
        or "что дальше" in q
        or "what is next" in q
    ):
        return "next_step"

    if (
        q.startswith("are ")
        or "already confirmed" in q
        or "confirmed?" in q
        or "подтверждены" in q
        or "уже подтверждены" in q
    ):
        return "confirmation"

    return "general_status"


def file_role(path: Path) -> str:
    s = str(path)
    name = path.name.lower()
    if "/artifacts/retrieval-execution/" in s and name == "answer.md":
        return "current_status"
    if "project-state" in s:
        return "context"
    if name == "summary.txt":
        return "supporting"
    if "contract" in name:
        return "contract"
    if "template" in name:
        return "template"
    return "seed"


def file_priority(path: Path) -> int:
    s = str(path)
    name = path.name.lower()

    if "/artifacts/retrieval-execution/" in s and name == "answer.md":
        return 95
    if s.endswith("/project-state/latest.md"):
        return 65
    if s.endswith("/project-state/latest.json"):
        return 60
    if "retrieval-planner-full-regress" in s and name == "summary.txt":
        return 45
    if "retrieval-planner-regress" in s and name == "summary.txt":
        return 35
    if "contract" in name:
        return -20
    if "template" in name:
        return -50
    return 0


def snippet_is_noise(path: Path, snippet: str) -> bool:
    name = path.name.lower()
    lower = snippet.lower()

    if snippet.count("<") >= 3 and snippet.count(">") >= 3:
        return True

    if "template" in name or "contract" in name:
        for marker in NOISE_MARKERS:
            if marker in lower:
                return True

    if lower.startswith("# retrieval execution answer") and "generated at" in lower:
        return True

    if "**generated at:**" in lower and "**topic:**" in lower:
        return True

    if lower.startswith('"version": "project-state-v1"'):
        return True

    if lower.startswith("{") and '"generated_at"' in lower and '"topic"' in lower:
        return True

    if "truth_source_mode" in lower and '"current_status"' in lower and '"summary": "string"' in lower:
        return True

    if '"overall_state": "green|yellow|red"' in lower:
        return True

    if lower.startswith("status: confirmed-green"):
        return True

    return False


def intent_bonus(intent: str, lower: str) -> int:
    score = 0

    if intent == "project_state":
        if '"overall_state": "green"' in lower:
            score += 30
        if "overall state: green" in lower:
            score += 30
        if "current project state is green" in lower:
            score += 25
        if '"next_step"' in lower or "следующий шаг" in lower:
            score -= 8

    elif intent == "next_step":
        if '"next_step"' in lower:
            score += 28
        if "следующий шаг" in lower or "переход к retrieval execution layer v1" in lower:
            score += 28
        if "retrieval execution layer v1" in lower:
            score += 16
        if '"overall_state": "green"' in lower or "overall state: green" in lower:
            score += 4

    elif intent == "confirmation":
        if "planner chain" in lower:
            score += 16
        if "auto-refresh" in lower:
            score += 16
        if "confirmed" in lower or "подтверждены" in lower:
            score += 16
        if '"overall_state": "green"' in lower or "overall state: green" in lower:
            score += 10

    else:
        if '"overall_state": "green"' in lower or "overall state: green" in lower:
            score += 10
        if '"next_step"' in lower or "следующий шаг" in lower:
            score += 10

    return score


def score_chunk(query: str, path: Path, snippet: str) -> int:
    score = file_priority(path)
    lower = snippet.lower()
    intent = query_intent(query)
    role = file_role(path)

    for term in query_terms(query):
        if term in lower:
            score += 3

    for hint in TRUTH_HINTS:
        if hint in lower:
            score += 4

    for pat, _ in STATUS_PATTERNS:
        if pat.search(snippet):
            score += 10

    score += intent_bonus(intent, lower)

    if "current summary" in lower:
        score += 8
    if '"current_status"' in lower:
        score += 4
    if '"summary":' in lower and '"overall_state": "green"' in lower:
        score += 8
    if '"next_step"' in lower and "retrieval execution layer v1" in lower:
        score += 12
    if "retrieval execution layer v1" in lower and ("подтверждены" in lower or "green" in lower):
        score += 8

    if role == "contract":
        score -= 15
    if role == "template":
        score -= 40

    return score


def build_evidence(files: List[Path], query: str, max_evidence: int = 5) -> List[Dict[str, Any]]:
    rows: List[Dict[str, Any]] = []

    for path in files:
        if not path.exists() or not path.is_file():
            continue
        if path.suffix.lower() not in TEXT_SUFFIXES:
            continue

        text = read_text(path)
        if not text.strip():
            continue

        for line_range, snippet in chunk_lines(text, max_lines=6):
            if snippet_is_noise(path, snippet):
                continue
            score = score_chunk(query, path, snippet)
            rows.append(
                {
                    "path": str(path),
                    "line_range": line_range,
                    "snippet": snippet[:1200],
                    "score": score,
                    "role": file_role(path),
                }
            )

    rows.sort(
        key=lambda x: (
            x["score"],
            1 if x["role"] == "context" else 0,
            -len(x["path"]),
            len(x["snippet"]),
        ),
        reverse=True,
    )

    picked: List[Dict[str, Any]] = []
    seen = set()
    role_counts: Dict[str, int] = {}
    file_counts: Dict[str, int] = {}

    for row in rows:
        key = (row["path"], row["line_range"])
        if key in seen:
            continue
        seen.add(key)

        if row["score"] < 1:
            continue

        role = row["role"]
        path_str = row["path"]

        if role in AUXILIARY_ROLE_LIMITS:
            if role_counts.get(role, 0) >= AUXILIARY_ROLE_LIMITS[role]:
                continue

        if role == "context" and role_counts.get(role, 0) >= CONTEXT_ROLE_LIMIT:
            continue

        if file_counts.get(path_str, 0) >= 2:
            continue

        if role == "contract" and role_counts.get("context", 0) >= 2 and row["score"] < 35:
            continue

        picked.append(row)
        role_counts[role] = role_counts.get(role, 0) + 1
        file_counts[path_str] = file_counts.get(path_str, 0) + 1

        if len(picked) >= max_evidence:
            break

    out: List[Dict[str, Any]] = []
    for idx, row in enumerate(picked, start=1):
        confidence = "high" if row["score"] >= 24 else "medium" if row["score"] >= 10 else "low"
        out.append(
            {
                "evidence_id": f"ev-{idx:03d}",
                "file": row["path"],
                "why_opened": "selected by planner or truth-layer fallback seed",
                "relevance": "supports the execution answer with directly opened file content",
                "lines": row["line_range"],
                "confidence": confidence,
                "snippet": row["snippet"],
                "score": row["score"],
                "role": row["role"],
            }
        )

    return out


def detect_answer_from_evidence(query: str, evidence: List[Dict[str, Any]]) -> Tuple[str, str, str]:
    if not evidence:
        return (
            "I could not confirm the answer from the opened files; evidence is insufficient.",
            "insufficient_evidence",
            "low",
        )

    joined = "\n".join(ev["snippet"] for ev in evidence)
    lower = joined.lower()
    intent = query_intent(query)

    has_green = (
        ("overall state" in lower and "green" in lower)
        or ('"overall_state": "green"' in lower)
        or "current project state is green" in lower
        or "current grounded project status is green" in lower
    )

    has_next = (
        ("retrieval execution layer v1" in lower and "next step" in lower)
        or ("retrieval execution layer v1" in lower and "next confirmed step" in lower)
        or ("retrieval execution layer v1" in lower and "следующий шаг" in lower)
        or ("retrieval execution layer v1" in lower and "переход к" in lower)
        or ('"next_step"' in lower and "retrieval execution layer v1" in lower)
    )

    has_planner = "planner chain" in lower
    has_refresh = (
        "auto-refresh" in lower
        or "truth layer" in lower
        or "truth-layer" in lower
        or "project-state" in lower
    )

    if intent == "project_state":
        if has_green:
            return (
                "The current project state is green.",
                "status",
                "high",
            )
        if has_next:
            return (
                "The current project state is green enough to proceed; the next confirmed step is Retrieval Execution Layer v1.",
                "status",
                "medium",
            )

    if intent == "next_step":
        if has_next and (has_planner or has_refresh or has_green):
            return (
                "The next confirmed step is Retrieval Execution Layer v1; planner chain and project-state auto-refresh are already confirmed green.",
                "status",
                "high",
            )
        if has_next:
            return (
                "The next confirmed step is Retrieval Execution Layer v1.",
                "status",
                "high",
            )

    if intent == "confirmation":
        if has_planner or has_refresh or has_green:
            return (
                "Yes — planner chain and project-state auto-refresh are already confirmed green.",
                "status",
                "high" if has_green else "medium",
            )
        if has_next:
            return (
                "There is evidence that the project is ready to proceed to Retrieval Execution Layer v1, but confirmation is only partial.",
                "status",
                "medium",
            )

    if has_next and (has_planner or has_refresh or has_green):
        return (
            "The next confirmed step is Retrieval Execution Layer v1; planner chain and project-state auto-refresh are already confirmed green.",
            "status",
            "high",
        )

    if has_next:
        return (
            "The next confirmed step is Retrieval Execution Layer v1.",
            "status",
            "high",
        )

    if has_green:
        return (
            "The current project state is green.",
            "status",
            "medium",
        )

    top = evidence[0]["snippet"].strip().splitlines()[0].strip()
    return (
        f"Best grounded result from the opened files: {top}",
        "summary",
        "medium" if evidence[0]["score"] >= 10 else "low",
    )


def build_bullets(final_answer: str, evidence: List[Dict[str, Any]]) -> List[str]:
    bullets: List[str] = []

    if final_answer.startswith("Yes —"):
        bullets.append("Planner chain and project-state auto-refresh are already confirmed green.")
    if "The current project state is green." in final_answer:
        bullets.append("The current project state is green.")
    if "Retrieval Execution Layer v1" in final_answer:
        bullets.append("The next confirmed step is Retrieval Execution Layer v1.")
    if "green" in final_answer.lower():
        bullets.append("Planner chain and project-state auto-refresh are already confirmed green.")

    for ev in evidence[:3]:
        role = ev.get("role", "seed")
        bullets.append(f"Supporting evidence came from {role} file: {ev['file']}.")

    uniq: List[str] = []
    seen = set()
    for item in bullets:
        if item not in seen:
            uniq.append(item)
            seen.add(item)

    return uniq[:5] or ["Grounded evidence was collected from opened files."]


def render_answer_md(
    generated_at: str,
    topic: str,
    query: str,
    status: str,
    answer_type: str,
    confidence: str,
    execution_dir: str,
    planner_source: str,
    final_answer: str,
    summary_bullets: List[str],
    evidence: List[Dict[str, Any]],
    opened_files: List[Dict[str, Any]],
    covered: List[str],
    uncertain: List[str],
    missing: List[str],
    notes: List[str],
) -> str:
    parts: List[str] = []

    parts.append("# Retrieval Execution Answer\n")
    parts.append(f"**Generated at:** `{generated_at}`  ")
    parts.append(f"**Topic:** `{topic}`  ")
    parts.append(f"**Query:** `{query}`  ")
    parts.append(f"**Execution status:** `{status}`  ")
    parts.append(f"**Answer type:** `{answer_type}`  ")
    parts.append(f"**Confidence:** `{confidence}`  ")
    parts.append(f"**Execution directory:** `{execution_dir}`  ")
    parts.append(f"**Planner source:** `{planner_source}`\n")

    parts.append("## Final Answer\n")
    parts.append(final_answer + "\n")

    parts.append("## Answer Summary\n")
    for bullet in summary_bullets:
        parts.append(f"- {bullet}")
    parts.append("")

    parts.append("## Evidence Used\n")
    if evidence:
        for idx, ev in enumerate(evidence, start=1):
            parts.append(f"### Evidence {idx}")
            parts.append(f"- **Evidence ID:** `{ev['evidence_id']}`")
            parts.append(f"- **File:** `{ev['file']}`")
            parts.append(f"- **Why opened:** `{ev['why_opened']}`")
            parts.append(f"- **Relevance:** `{ev['relevance']}`")
            parts.append(f"- **Lines:** `{ev['lines']}`")
            parts.append(f"- **Confidence:** `{ev['confidence']}`\n")
            parts.append(f"> {ev['snippet'].replace(chr(10), chr(10) + '> ')}\n")
    else:
        parts.append("No evidence blocks were produced.\n")

    parts.append("## Opened Files Summary\n")
    parts.append("| File | Role | Used in final answer | Notes |")
    parts.append("|---|---|---:|---|")
    for row in opened_files:
        parts.append(
            f"| `{row['file']}` | `{row['role']}` | `{row['used_in_final_answer']}` | `{row['notes']}` |"
        )
    parts.append("")

    parts.append("## Coverage and Gaps\n")
    parts.append("### Covered")
    for item in covered:
        parts.append(f"- {item}")
    parts.append("")

    parts.append("### Uncertain")
    for item in uncertain:
        parts.append(f"- {item}")
    parts.append("")

    parts.append("### Missing")
    for item in missing:
        parts.append(f"- {item}")
    parts.append("")

    parts.append("## Machine Artifacts\n")
    for name in (
        "execution-manifest.json",
        "opened-files.json",
        "evidence.jsonl",
        "answer.json",
        "ANSWER.md",
    ):
        parts.append(f"- `{name}`")
    parts.append("")

    if notes:
        parts.append("## Execution Notes\n")
        for note in notes:
            parts.append(f"- {note}")
        parts.append("")

    return "\n".join(parts).rstrip() + "\n"


def choose_open_files(path_candidates: List[Path], topic: str, query: str, max_open: int) -> List[Path]:
    ranked: List[Tuple[int, Path]] = []
    seen = set()

    for p in path_candidates + truth_seed_paths(topic, query):
        try:
            rp = p.resolve() if p.exists() else p
        except Exception:
            rp = p

        if not rp.exists() or not rp.is_file():
            continue
        if rp.suffix.lower() not in TEXT_SUFFIXES:
            continue

        key = str(rp)
        if key in seen:
            continue
        seen.add(key)
        ranked.append((file_priority(rp), rp))

    ranked.sort(key=lambda item: item[0], reverse=True)
    return [p for _, p in ranked[:max_open]]


def ensure_latest_link(base_dir: Path, out_dir: Path) -> None:
    latest = base_dir / "latest"
    try:
        if latest.is_symlink() or latest.exists():
            if latest.is_dir() and not latest.is_symlink():
                return
            latest.unlink()
        latest.symlink_to(out_dir.name)
    except Exception:
        pass


def make_unique_out_dir(base_dir: Path) -> Path:
    base_dir.mkdir(parents=True, exist_ok=True)

    for _ in range(5):
        candidate = base_dir / stamp_seconds()
        try:
            candidate.mkdir(parents=False, exist_ok=False)
            return candidate
        except FileExistsError:
            time.sleep(1.05)

    fail(f"could not allocate unique output directory in {base_dir}")
    raise RuntimeError("unreachable")


def write_json(path: Path, obj: Any) -> None:
    path.write_text(json.dumps(obj, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def write_jsonl(path: Path, rows: List[Dict[str, Any]]) -> None:
    with path.open("w", encoding="utf-8") as f:
        for row in rows:
            f.write(json.dumps(row, ensure_ascii=False) + "\n")


def main() -> int:
    ap = argparse.ArgumentParser(description="Retrieval Execution Layer v1 runner")
    ap.add_argument("--topic", default=DEFAULT_TOPIC)
    ap.add_argument("--plan", help="Path to planner artifact dir or file")
    ap.add_argument("--query", help="Execution query override")
    ap.add_argument("--max-open", type=int, default=6)
    ap.add_argument("--max-evidence", type=int, default=5)
    args = ap.parse_args()

    topic = args.topic

    if args.plan:
        plan_path = Path(args.plan)
        plan_dir = plan_path if plan_path.is_dir() else plan_path.parent
    else:
        plan_dir = planner_latest_dir(topic)

    if plan_dir is None or not plan_dir.exists():
        print("ERROR: planner artifact directory not found", file=sys.stderr)
        return 2

    plan_query, plan_paths, plan_files = gather_plan_context(plan_dir)
    query = (args.query or plan_query or "What is the current grounded project status?").strip()

    open_files = choose_open_files(plan_paths, topic, query, args.max_open)
    evidence = build_evidence(open_files, query, args.max_evidence)

    final_answer, answer_type, confidence = detect_answer_from_evidence(query, evidence)
    if evidence and confidence == "high":
        status = "ok"
    elif evidence:
        status = "partial"
    else:
        status = "insufficient_evidence"

    used_paths = {ev["file"] for ev in evidence}
    opened_rows: List[Dict[str, Any]] = []
    for p in open_files:
        opened_rows.append(
            {
                "file": str(p),
                "role": file_role(p),
                "used_in_final_answer": "yes" if str(p) in used_paths else "no",
                "notes": "opened during execution",
            }
        )

    covered: List[str] = []
    if evidence:
        covered.append("Grounded answer was built only from files opened during execution.")
    if "Retrieval Execution Layer v1" in final_answer:
        covered.append("The next confirmed implementation step is Retrieval Execution Layer v1.")
    if "green" in final_answer.lower():
        covered.append("Planner chain and project-state auto-refresh are confirmed green in the opened evidence.")
    if not covered:
        covered.append("Execution completed and collected at least partial evidence.")

    uncertain = [
        "Line-level selection is still heuristic in v1.",
        "Evidence ranking is intentionally simple, but auxiliary noise suppression is now stronger.",
    ]

    missing: List[str] = []
    if not evidence:
        missing.append("No usable evidence snippets were extracted.")
    if not plan_paths:
        missing.append("Planner artifact did not yield usable seed file paths; truth-layer fallback seeds were used.")
    missing.append("A richer answer composer can be added in the next iteration.")

    summary_bullets = build_bullets(final_answer, evidence)
    generated_at = now_utc()

    base_dir = ROOT / topic / "artifacts" / "retrieval-execution"
    out_dir = make_unique_out_dir(base_dir)
    ensure_latest_link(base_dir, out_dir)

    planner_source = str(plan_dir)

    manifest = {
        "generated_at": generated_at,
        "runner": "run-retrieval-execution-v1",
        "topic": topic,
        "query": query,
        "execution_status": status,
        "answer_type": answer_type,
        "confidence": confidence,
        "planner_source": planner_source,
        "opened_file_count": len(opened_rows),
        "evidence_count": len(evidence),
        "artifacts": [
            "execution-manifest.json",
            "opened-files.json",
            "evidence.jsonl",
            "answer.json",
            "ANSWER.md",
        ],
        "plan_json_files": [str(p) for p in plan_files],
    }

    answer_json = {
        "final_answer": final_answer,
        "answer_type": answer_type,
        "confidence": confidence,
        "summary_bullets": summary_bullets,
        "covered": covered,
        "uncertain": uncertain,
        "missing": missing,
    }

    notes: List[str] = []
    if not plan_paths:
        notes.append("Planner-derived file paths were not available; truth-layer files were used as fallback seeds.")
    if evidence and any(ev.get("role") in {"template", "contract"} for ev in evidence):
        notes.append("Auxiliary contract/template evidence was retained only as secondary support.")
    if not evidence:
        notes.append("Execution completed structurally, but without enough evidence for a grounded answer.")
    notes.append("Output directory allocation now avoids same-second artifact collisions.")

    answer_md = render_answer_md(
        generated_at=generated_at,
        topic=topic,
        query=query,
        status=status,
        answer_type=answer_type,
        confidence=confidence,
        execution_dir=str(out_dir),
        planner_source=planner_source,
        final_answer=final_answer,
        summary_bullets=summary_bullets,
        evidence=evidence,
        opened_files=opened_rows,
        covered=covered,
        uncertain=uncertain,
        missing=missing,
        notes=notes,
    )

    write_json(out_dir / "execution-manifest.json", manifest)
    write_json(out_dir / "opened-files.json", {"opened_files": opened_rows})
    write_jsonl(out_dir / "evidence.jsonl", evidence)
    write_json(out_dir / "answer.json", answer_json)
    (out_dir / "ANSWER.md").write_text(answer_md, encoding="utf-8")

    print(f"OUTDIR={out_dir}")
    print(f"STATUS={status}")
    print(f"ANSWER_TYPE={answer_type}")
    print(f"CONFIDENCE={confidence}")
    print(f"OPENED_FILES={len(opened_rows)}")
    print(f"EVIDENCE_COUNT={len(evidence)}")
    print(f"ANSWER_FILE={out_dir / 'ANSWER.md'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
