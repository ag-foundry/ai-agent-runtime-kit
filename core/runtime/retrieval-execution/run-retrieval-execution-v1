def now_utc() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def stamp_seconds() -> str:
    return datetime.now().strftime("%Y-%m-%d-%H%M%S")


def read_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return path.read_text(encoding="utf-8", errors="replace")


def safe_json_load(path: Path) -> Any:
    try:
        return json.loads(read_text(path))
    except Exception:
        return None


def iter_strings(obj: Any) -> Sequence[str]:
    out: List[str] = []

    def walk(x: Any) -> None:
        if isinstance(x, str):
            out.append(x)
        elif isinstance(x, dict):
            for v in x.values():
                walk(v)
        elif isinstance(x, list):
            for v in x:
                walk(v)

    walk(obj)
    return out


def looks_like_path(value: str) -> bool:
    if not value or len(value) > 500:
        return False
    if value.startswith("/home/agent/") or value.startswith("core/") or value.startswith("agents/"):
        return True
    suffix = Path(value).suffix.lower()
    if suffix in TEXT_SUFFIXES and ("/" in value or value.startswith(".")):
        return True
    return False


def normalize_path(value: str) -> Optional[Path]:
    p = Path(value)
    if p.is_absolute():
        return p
    if value.startswith("agents/"):
        return Path("/home/agent") / value
    if value.startswith("core/") or value.startswith("audit-smoke/"):
        return ROOT / value
    return None


def planner_latest_dir(topic: str) -> Optional[Path]:
    base = ROOT / topic / "artifacts" / "retrieval-plans"
    latest = base / "latest"
    if latest.exists():
        return latest.resolve()
    if not base.exists():
        return None
    dirs = [p for p in base.iterdir() if p.is_dir()]
    if not dirs:
        return None
    return sorted(dirs, key=lambda p: p.stat().st_mtime, reverse=True)[0]


def extract_query_and_paths_from_json(obj: Any) -> Tuple[Optional[str], List[Path]]:
    query: Optional[str] = None
    paths: List[Path] = []

    def walk(x: Any) -> None:
        nonlocal query
        if isinstance(x, dict):
            for k, v in x.items():
                lk = str(k).lower()
                if query is None and lk in QUERY_KEYS and isinstance(v, str) and v.strip():
                    query = v.strip()
                if lk in PATH_HINT_KEYS:
                    for s in iter_strings(v):
                        if looks_like_path(s):
                            pp = normalize_path(s)
                            if pp is not None:
                                paths.append(pp)
                walk(v)
        elif isinstance(x, list):
            for v in x:
                walk(v)
        elif isinstance(x, str):
            if looks_like_path(x):
                pp = normalize_path(x)
                if pp is not None:
                    paths.append(pp)

    walk(obj)

    uniq: List[Path] = []
    seen = set()
    for p in paths:
        rp = str(p)
        if rp not in seen:
            uniq.append(p)
            seen.add(rp)
    return query, uniq


def gather_plan_context(plan_dir: Path) -> Tuple[Optional[str], List[Path], List[Path]]:
    json_files = sorted(list(plan_dir.glob("*.json")) + list(plan_dir.glob("*.jsonl")))
    found_query: Optional[str] = None
    found_paths: List[Path] = []

    for jf in json_files:
        obj = safe_json_load(jf)
        if obj is None:
            continue
        q, paths = extract_query_and_paths_from_json(obj)
        if found_query is None and q:
            found_query = q
        found_paths.extend(paths)

    dedup: List[Path] = []
    seen = set()
    for p in found_paths:
        key = str(p.resolve()) if p.exists() else str(p)
        if key not in seen:
            dedup.append(p)
            seen.add(key)

    return found_query, dedup, json_files


