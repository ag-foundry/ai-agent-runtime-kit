#!/usr/bin/env bash
set -euo pipefail

AGENT_REPO_ROOT="${AGENT_REPO_ROOT:-${HOME}/agents}"
META_LAUNCHER="$AGENT_REPO_ROOT/core/artifacts/skills/openclaw-skill-creator-v1/scripts/launch_ai_meta_workflow.py"

usage() {
  cat <<'EOF'
Usage:
  codex-frontdoor-preflight "<естественный запрос>"
  codex-frontdoor-preflight --topic <topic> "<естественный запрос>"
  codex-frontdoor-preflight --task-request "<естественный запрос>"

Notes:
  - This is the Codex-chat binding helper, not a separate human workflow.
  - It runs the global AI meta-launcher in preflight-only mode for substantial Codex work.
  - The resulting contract/manifest/trace tell Codex whether to stay in the current chat
    or delegate to a narrower managed/current-state/research backend.
  - Env AGENT_REPO_ROOT allows a non-default repo root when the kit is not installed at ${HOME}/agents.
EOF
}

if [[ $# -eq 0 ]]; then
  usage
  exit 2
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

if [[ ! -f "$META_LAUNCHER" ]]; then
  echo "ERROR: meta-launcher backend not found: $META_LAUNCHER" >&2
  exit 1
fi

exec python3 "$META_LAUNCHER" --frontdoor-source codex_chat --preflight-only "$@"
