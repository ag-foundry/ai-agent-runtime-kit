#!/usr/bin/env bash
set -euo pipefail

AGENT_REPO_ROOT="${AGENT_REPO_ROOT:-${HOME}/agents}"
LAUNCHER="$AGENT_REPO_ROOT/core/artifacts/skills/openclaw-skill-creator-v1/scripts/launch_managed_workflow.py"
BASE="$AGENT_REPO_ROOT"
SHARED="$BASE/_shared"
PROFILES="$SHARED/profiles"

PROFILE=""
NO_CODEX="0"
BOOTSTRAP_ROOT="$BASE"
TOPIC=""

usage() {
  cat <<'EOF'
Usage:
  agent-topic <topic> [--profile <name>] [--bootstrap-root <dir>] [--no-codex]

Examples:
  agent-topic server-ops
  agent-topic release-review --no-codex
  agent-topic research-sandbox --bootstrap-root "$HOME/work/agents"

Notes:
  - Это compatibility alias поверх managed topic bootstrap.
  - Default server AI entrypoint после bootstrap: /home/agent/bin/agent-exec
  - Env AGENT_REPO_ROOT позволяет использовать repo root вне стандартного ${HOME}/agents.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE="${2:-}"; shift 2 ;;
    --bootstrap-root)
      BOOTSTRAP_ROOT="${2:-}"; shift 2 ;;
    --no-codex)
      NO_CODEX="1"; shift ;;
    -h|--help)
      usage; exit 0 ;;
    *)
      if [[ -z "$TOPIC" ]]; then
        TOPIC="$1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$TOPIC" ]]; then
  usage
  exit 1
fi

if [[ ! -f "$LAUNCHER" ]]; then
  echo "ERROR: managed launcher not found: $LAUNCHER" >&2
  exit 1
fi

python3 "$LAUNCHER" \
  --workflow-class topic_bootstrap \
  --topic-name "$TOPIC" \
  --bootstrap-root "$BOOTSTRAP_ROOT" \
  --force \
  --task-request "compatibility bootstrap alias agent-topic $TOPIC"

DIR="$BOOTSTRAP_ROOT/$TOPIC"
mkdir -p "$PROFILES"

if [[ -n "$PROFILE" ]]; then
  SRC="$PROFILES/$PROFILE.md"
  if [[ -f "$SRC" ]]; then
    cp -a "$SRC" "$DIR/PROFILE.md"
  else
    cat > "$DIR/PROFILE.md" <<MD
# PROFILE: $PROFILE
(Не найден шаблон: $SRC)
MD
  fi
fi

if [[ "$NO_CODEX" == "1" ]]; then
  echo "OK: topic bootstrapped at $DIR"
  echo "Next step: agent-exec --topic $TOPIC \"подними память по теме и предложи следующий шаг\""
  exit 0
fi

cd "$DIR"
exec codex
