#!/usr/bin/env python3
# -*- coding: utf-8 -*-
from __future__ import annotations

import argparse
import datetime as dt
import os
import re
import shutil
import subprocess
from pathlib import Path

TARGET_DEFAULT = Path("/home/agent/bin/codex-upgrade")

def ts() -> str:
    return dt.datetime.now().strftime("%Y%m%d-%H%M%S")

def run_py_compile(path: Path) -> tuple[bool, str]:
    p = subprocess.run(
        ["python3", "-m", "py_compile", str(path)],
        capture_output=True,
        text=True
    )
    ok = (p.returncode == 0)
    out = (p.stdout or "") + (p.stderr or "")
    return ok, out.strip()

def backup(path: Path) -> Path:
    b = path.with_name(path.name + f".bak-{ts()}")
    shutil.copy2(path, b)
    return b

def normalize_to_utf8(path: Path) -> str:
    """
    Normalize line endings (CRLF/NEL -> LF), and ensure UTF-8.
    Try decode as UTF-8, then CP1251 (most common for RU).
    """
    b = path.read_bytes()
    # normalize line endings: CRLF and NEL -> LF
    b = b.replace(b"\r\n", b"\n").replace(b"\x85", b"\n")

    used = None
    for enc in ("utf-8", "cp1251"):
        try:
            text = b.decode(enc)
            used = enc
            break
        except UnicodeDecodeError:
            continue

    if used is None:
        raise RuntimeError("Cannot decode file as utf-8 or cp1251")

    path.write_text(text, encoding="utf-8", newline="\n")
    os.chmod(path, 0o755)
    return used

def codex_upgrade_template() -> str:
    """
    Guaranteed-working codex-upgrade (v3) without nested triple-quote traps.
    Writes/updates: _shared docs, commands, skills, wrappers, TODOs, TASK.md.
    """
    return r"""#!/usr/bin/env python3
# -*- coding: utf-8 -*-
from __future__ import annotations

import argparse
import datetime as dt
import re
import shutil
from pathlib import Path

HOME = Path.home()
AGENTS = HOME / "agents"
SHARED = AGENTS / "_shared"
BIN = HOME / "bin"
TEMPLATES_BIN = SHARED / "templates" / "bin"

TOPICS = [
    "core","vuplus","epg","vpn","router","minipc","mcp","accounting","skins-plugins","bonding"
]

BEGIN = "<!-- BEGIN {name} -->"
END = "<!-- END {name} -->"

def now_ts() -> str:
    return dt.datetime.now().strftime("%Y%m%d-%H%M%S")

def ensure_dir(p: Path) -> None:
    p.mkdir(parents=True, exist_ok=True)

def backup_file(p: Path, stamp: str) -> Path:
    b = p.with_name(p.name + f".bak-{stamp}")
    shutil.copy2(p, b)
    return b

def upsert_section(p: Path, name: str, body: str, stamp: str) -> None:
    start = BEGIN.format(name=name)
    end = END.format(name=name)

    if not p.exists():
        ensure_dir(p.parent)
        p.write_text(f"{start}\n{body.rstrip()}\n{end}\n", encoding="utf-8")
        return

    old = p.read_text(encoding="utf-8", errors="ignore")
    if start in old and end in old:
        pattern = re.compile(re.escape(start) + r".*?" + re.escape(end), re.DOTALL)
        new_block = f"{start}\n{body.rstrip()}\n{end}"
        new = pattern.sub(new_block, old, count=1)
        if new != old:
            backup_file(p, stamp)
            p.write_text(new, encoding="utf-8")
    else:
        backup_file(p, stamp)
        p.write_text(old.rstrip() + "\n\n" + f"{start}\n{body.rstrip()}\n{end}\n", encoding="utf-8")

def write_file(p: Path, content: str, stamp: str, executable: bool=False) -> None:
    ensure_dir(p.parent)
    if p.exists():
        backup_file(p, stamp)
    p.write_text(content.rstrip() + "\n", encoding="utf-8", newline="\n")
    if executable:
        p.chmod(0o755)

def install_exec(name: str, content: str, stamp: str) -> None:
    write_file(BIN / name, content, stamp, executable=True)
    ensure_dir(TEMPLATES_BIN)
    write_file(TEMPLATES_BIN / name, content, stamp, executable=True)

def ensure_task(topic: str, stamp: str) -> None:
    d = AGENTS / topic
    if not d.exists():
        return
    p = d / "TASK.md"
    if p.exists() and p.stat().st_size > 30:
        return
    txt = f"""# TASK (входная задача)

Напиши задачу сюда, затем:

- PLAN:   `agent-plan {topic}`
- DO:     `agent-do {topic}`
- REVIEW:  `agent-review {topic}`

## Что указать
- Цель (результат)
- Ограничения (что нельзя трогать)
- DoD (как понять, что готово)
- Риски/особенности

## Текст задачи
(замени этот текст на свою задачу)
"""
    write_file(p, txt, stamp, executable=False)

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args()

    stamp = now_ts()

    # Shared dirs
    ensure_dir(SHARED / "commands")
    ensure_dir(SHARED / "skills")
    ensure_dir(SHARED / "artifacts" / "dashboard")

    # AGENTS.md: operational protocol
    agents_md = SHARED / "AGENTS.md"
    ops = """## Операционный протокол (PLAN → DO → REVIEW)

### Стандарт
1) TASK: записать задачу в `~/agents/<topic>/TASK.md`
2) PLAN: `agent-plan <topic>` (read-only, без изменений)
3) DO: `agent-do <topic>` (edit, строго по плану)
4) REVIEW: `agent-review <topic>` (fresh run, read-only)

### Команды и Skills
- Команды (процедуры): `~/agents/_shared/commands/*.md`
- Skills (процессы): `~/agents/_shared/skills/`

### MCP
MCP выключены по умолчанию. Каждый MCP — через ADR и явный approval на опасные действия.

### Большие файлы
Большие файлы НЕ вставлять в терминал.
Notepad++: UTF-8 + Unix LF → Termius SFTP → `/home/agent/bin/` → запуск короткой командой.
"""
    upsert_section(agents_md, "OPS_WORKFLOW_V3", ops, stamp)

    # README.md: quickstart + roadmap
    readme = SHARED / "README.md"
    roadmap = """## Быстрый старт

- `agent-topic <topic> --profile <name> --no-codex` (создать скелет)
- Заполнить `~/agents/<topic>/TASK.md`
- `agent-plan <topic>`
- `agent-do <topic>`
- `agent-review <topic>`
- `agent-close-day`

## Дорожная карта

P0: PLAN→DO→REVIEW + команды + close-day + dashboard
P1: Skills (vpn/vuplus/epg) + индексация артефактов
P2: MCP registry + policy + ADR
P3: subagents/swarm (research/build/audit)
"""
    upsert_section(readme, "QUICKSTART_ROADMAP_V3", roadmap, stamp)

    # START_HERE.md
    start_here = SHARED / "START_HERE.md"
    write_file(start_here, """# START HERE

1) Выбери тему: vpn/vuplus/epg/...
2) Запиши задачу в TASK.md
3) PLAN: agent-plan <topic>
4) DO: agent-do <topic>
5) REVIEW: agent-review <topic>

Правило: большие файлы — Notepad++ (UTF-8/LF) → SFTP → /home/agent/bin/
""", stamp, executable=False)

    # commands
    cmd_plan = """---
mode: readonly
name: plan
---
# PLAN
Сформируй план (3–7 шагов) + DoD + риски + проверки + откат.
Никаких правок файлов.
"""
    cmd_do = """---
mode: edit
name: do
---
# DO
Выполни строго по последнему плану из artifacts/plans/.
Пиши артефакты в artifacts/, решения в DECISIONS/, лог в LOG.md.
"""
    cmd_review = """---
mode: readonly
name: review
---
# REVIEW
Свежая проверка: безопасность/структура/риски.
Никаких правок.
"""
    cmd_close = """---
mode: readonly
name: close-day
---
# CLOSE DAY
Собери итоги дня по темам: что сделано + токены.
"""
    write_file(SHARED / "commands" / "plan.md", cmd_plan, stamp)
    write_file(SHARED / "commands" / "do.md", cmd_do, stamp)
    write_file(SHARED / "commands" / "review.md", cmd_review, stamp)
    write_file(SHARED / "commands" / "close-day.md", cmd_close, stamp)

    # minimal skill
    write_file(SHARED / "skills" / "skill-plan-do-review.md",
               "# Skill: PLAN→DO→REVIEW\n\nПрименять для всех задач средней сложности.\n",
               stamp, executable=False)

    # wrappers
    agent_cmd = r"""#!/usr/bin/env bash
set -euo pipefail
if [[ $# -lt 2 ]]; then echo "Usage: agent-cmd <topic> <command> [args...]"; exit 2; fi
TOPIC="$1"; shift
CMD="$1"; shift || true
DIR="$HOME/agents/$TOPIC"
[[ -d "$DIR" ]] || { echo "ERROR: no topic dir: $DIR"; exit 1; }
CMD_FILE="$HOME/agents/_shared/commands/$CMD.md"
[[ -f "$CMD_FILE" ]] || { echo "ERROR: no command: $CMD_FILE"; exit 1; }
MODE="readonly"; grep -q "^mode: edit" "$CMD_FILE" && MODE="edit"
PROMPT="$(cat "$CMD_FILE")"
[[ $# -gt 0 ]] && PROMPT="$PROMPT"$'\n\n## Args\n'"$*"
AGENT_MODE="$MODE" agent-exec "$TOPIC" "$PROMPT"
"""
    agent_plan = r"""#!/usr/bin/env bash
set -euo pipefail
TOPIC="${1:-}"; [[ -n "$TOPIC" ]] || { echo "Usage: agent-plan <topic>"; exit 2; }
DIR="$HOME/agents/$TOPIC"; [[ -d "$DIR" ]] || { echo "ERROR: no topic dir: $DIR"; exit 1; }
TASK="$DIR/TASK.md"; [[ -s "$TASK" ]] || { echo "ERROR: empty TASK.md: $TASK"; exit 1; }
PLAN_DIR="$DIR/artifacts/plans"; mkdir -p "$PLAN_DIR"
OUT="$(AGENT_MODE=readonly agent-exec "$TOPIC" "$(cat "$HOME/agents/_shared/commands/plan.md")"$'\n\n## TASK\n'"$(cat "$TASK")")"
RUN_ID="$(echo "$OUT" | sed -n 's/^OK: run_id=//p' | tail -n 1)"
[[ -n "$RUN_ID" ]] || { echo "$OUT"; echo "ERROR: no run_id"; exit 1; }
cp "$DIR/runs/$RUN_ID.last.md" "$PLAN_DIR/$RUN_ID.plan.md" || true
echo "PLAN: $PLAN_DIR/$RUN_ID.plan.md"
"""
    agent_do = r"""#!/usr/bin/env bash
set -euo pipefail
TOPIC="${1:-}"; [[ -n "$TOPIC" ]] || { echo "Usage: agent-do <topic>"; exit 2; }
DIR="$HOME/agents/$TOPIC"; [[ -d "$DIR" ]] || { echo "ERROR: no topic dir: $DIR"; exit 1; }
PLAN_DIR="$DIR/artifacts/plans"
LATEST="$(ls -t "$PLAN_DIR"/*.plan.md 2>/dev/null | head -n 1 || true)"
[[ -n "$LATEST" ]] || { echo "ERROR: no plan. Run agent-plan $TOPIC"; exit 1; }
PROMPT="$(cat "$HOME/agents/_shared/commands/do.md")"$'\n\n## Latest plan\n'"$(cat "$LATEST")"
AGENT_MODE=edit agent-exec "$TOPIC" "$PROMPT"
"""
    agent_review = r"""#!/usr/bin/env bash
set -euo pipefail
TOPIC="${1:-}"; [[ -n "$TOPIC" ]] || { echo "Usage: agent-review <topic>"; exit 2; }
AGENT_MODE=readonly agent-exec "$TOPIC" "$(cat "$HOME/agents/_shared/commands/review.md")"
"""
    agent_close_day = r"""#!/usr/bin/env bash
set -euo pipefail
DATE="${1:-$(date +%F)}"
OUT="$HOME/agents/_shared/memory/note-${DATE//-/}-close-day.md"
mkdir -p "$(dirname "$OUT")"
echo "# Close Day: $DATE" > "$OUT"
echo "Generated: $(date -Is)" >> "$OUT"
echo "" >> "$OUT"
total_in=0; total_out=0
for d in "$HOME/agents"/*; do
  t="$(basename "$d")"; [[ "$t" == "_shared" ]] && continue
  [[ -d "$d/runs" ]] || continue
  files=( "$d/runs/${DATE}-"*.summary.md )
  [[ -e "${files[0]}" ]] || continue
  echo "## Topic: $t" >> "$OUT"
  sin=0; sout=0
  for f in "${files[@]}"; do
    in_tok="$(grep -E 'input_tokens:' "$f" | awk '{print $2}' || echo 0)"
    out_tok="$(grep -E 'output_tokens:' "$f" | awk '{print $2}' || echo 0)"
    sin=$((sin + in_tok)); sout=$((sout + out_tok))
  done
  total_in=$((total_in + sin)); total_out=$((total_out + sout))
  echo "- totals: input=$sin output=$sout" >> "$OUT"
  echo "" >> "$OUT"
done
echo "---" >> "$OUT"
echo "ALL: input=$total_in output=$total_out" >> "$OUT"
echo "OK: $OUT"
"""
    agent_dash_build = r"""#!/usr/bin/env bash
set -euo pipefail
python3 - <<'PY'
import json, re
from pathlib import Path
from datetime import datetime
HOME = Path.home()
AGENTS = HOME / "agents"
OUT = AGENTS / "_shared" / "artifacts" / "dashboard"
OUT.mkdir(parents=True, exist_ok=True)

def parse_summary(p: Path):
    t = p.read_text(encoding="utf-8", errors="ignore")
    m_in = re.search(r"input_tokens:\s*(\d+)", t)
    m_out= re.search(r"output_tokens:\s*(\d+)", t)
    return {"run_id": p.stem.replace(".summary",""),
            "ts": p.name[:19],
            "input_tokens": int(m_in.group(1)) if m_in else 0,
            "output_tokens": int(m_out.group(1)) if m_out else 0}

data = {"generated": datetime.now().isoformat(timespec="seconds"), "topics": {}}
for d in AGENTS.iterdir():
    if not d.is_dir() or d.name == "_shared": continue
    runs = d / "runs"
    if not runs.exists(): continue
    items = [parse_summary(p) for p in sorted(runs.glob("*.summary.md"))][-300:]
    if items: data["topics"][d.name] = items

(OUT/"data.json").write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")

html = r'''<!doctype html><html lang="ru"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Codex Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
body{font-family:system-ui,Segoe UI,Arial;margin:20px;max-width:1200px}
.card{border:1px solid #ddd;border-radius:12px;padding:14px;margin:12px 0}
small{color:#666} select{padding:6px 10px;border-radius:10px}
table{border-collapse:collapse;width:100%}
td,th{border-bottom:1px solid #eee;padding:8px;text-align:left;font-variant-numeric:tabular-nums}
</style></head><body>
<h1>Codex Dashboard</h1><small id="meta"></small>
<div class="card"><label>Тема: <select id="topic"></select></label></div>
<div class="card"><h3>Tokens per run</h3><canvas id="chart" height="90"></canvas></div>
<div class="card"><h3>Latest runs</h3>
<table><thead><tr><th>ts</th><th>run_id</th><th>input</th><th>output</th></tr></thead><tbody id="rows"></tbody></table></div>
<script>
let chart;
function render(d,t){const r=d.topics[t]||[];
const labels=r.map(x=>x.ts), inp=r.map(x=>x.input_tokens||0), out=r.map(x=>x.output_tokens||0);
if(chart) chart.destroy();
chart=new Chart(document.getElementById('chart'),{type:'line',data:{labels,datasets:[
{label:'input_tokens',data:inp},{label:'output_tokens',data:out}]},
options:{responsive:true,interaction:{mode:'index',intersect:false}}});
const rr=[...r].reverse().slice(0,60);
rows.innerHTML=rr.map(x=>`<tr><td>${x.ts}</td><td>${x.run_id}</td><td>${x.input_tokens}</td><td>${x.output_tokens}</td></tr>`).join('');
}
fetch('./data.json').then(r=>r.json()).then(d=>{
meta.textContent=`generated: ${d.generated} | topics: ${Object.keys(d.topics).length}`;
const keys=Object.keys(d.topics).sort(); keys.forEach(k=>{const o=document.createElement('option');o.value=k;o.textContent=k;topic.appendChild(o);});
if(keys[0]){topic.value=keys[0];render(d,keys[0]);topic.addEventListener('change',()=>render(d,topic.value));}
});
</script></body></html>'''
(OUT/"index.html").write_text(html, encoding="utf-8")
print("OK:", OUT)
PY
echo "OK: built $HOME/agents/_shared/artifacts/dashboard/index.html"
"""
    agent_dash_serve = r"""#!/usr/bin/env bash
set -euo pipefail
cd "$HOME/agents/_shared/artifacts/dashboard"
python3 -m http.server 8088 --bind 127.0.0.1
"""

    install_exec("agent-cmd", agent_cmd, stamp)
    install_exec("agent-plan", agent_plan, stamp)
    install_exec("agent-do", agent_do, stamp)
    install_exec("agent-review", agent_review, stamp)
    install_exec("agent-close-day", agent_close_day, stamp)
    install_exec("agent-dashboard-build", agent_dash_build, stamp)
    install_exec("agent-dashboard-serve", agent_dash_serve, stamp)

    # Update TODOs
    core_todo = AGENTS / "core" / "TODO.md"
    upsert_section(core_todo, "CLOUDCODE_ROADMAP_V3",
                   "## CloudCode-перенос (порядок)\n\nP0: протокол + команды + close-day + dashboard\nP1: skills + индексация\nP2: MCP registry + policy + ADR\nP3: subagents/swarm\n",
                   stamp)

    mcp_todo = AGENTS / "mcp" / "TODO.md"
    upsert_section(mcp_todo, "MCP_PLAN_V3",
                   "## MCP (безопасно)\n\n1) registry\n2) policy allow/deny/conditional\n3) ADR per MCP\n4) safe read-only MCP first\n",
                   stamp)

    # TASK.md everywhere
    for t in TOPICS:
        ensure_task(t, stamp)

    print("DONE. Next:")
    print("  agent-health core quick")
    print("  fill ~/agents/<topic>/TASK.md")
    print("  agent-plan <topic>")

if __name__ == "__main__":
    main()
"""

def rebuild_target(path: Path) -> None:
    txt = codex_upgrade_template()
    path.write_text(txt, encoding="utf-8", newline="\n")
    os.chmod(path, 0o755)

def main():
    ap = argparse.ArgumentParser(description="Scan+fix codex-upgrade in one pass.")
    ap.add_argument("--target", default=str(TARGET_DEFAULT), help="Path to codex-upgrade")
    ap.add_argument("--no-rebuild", action="store_true", help="Do not rebuild, only normalize encoding/lines.")
    args = ap.parse_args()

    target = Path(args.target)

    if not target.exists():
        raise SystemExit(f"ERROR: target not found: {target}")

    print(f"[1] Target: {target}")
    bkp = backup(target)
    print(f"[1] Backup: {bkp}")

    print("[2] Normalize encoding/line-endings -> UTF-8/LF ...")
    used = normalize_to_utf8(target)
    print(f"[2] Decoded as: {used} -> written UTF-8/LF")

    ok, out = run_py_compile(target)
    if ok:
        print("[3] PY OK after normalize.")
        print("DONE.")
        return

    print("[3] Still failing after normalize:")
    print(out)

    if args.no_rebuild:
        print("STOP: --no-rebuild set. Keeping normalized file (may still be invalid).")
        raise SystemExit(2)

    print("[4] Rebuild codex-upgrade to known-good template ...")
    backup(target)
    rebuild_target(target)

    ok2, out2 = run_py_compile(target)
    if ok2:
        print("[5] PY OK after rebuild.")
        print("DONE. Now run:")
        print("  /home/agent/bin/codex-upgrade --dry-run")
        print("  /home/agent/bin/codex-upgrade")
        return

    print("[5] Rebuild failed (unexpected). Output:")
    print(out2)
    raise SystemExit(3)

if __name__ == "__main__":
    main()