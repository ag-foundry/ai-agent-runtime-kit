mode_limits = {
    "none": {
        "metadata_candidates_max": 0,
        "bucket_caps": {},
    },
    "quick": {
        "metadata_candidates_max": 6,
        "bucket_caps": {
            "official_docs": 2,
              "active_repositories": 1,
            "similar_solutions": 3,
            "issue_problem_sources": 1,
            "platform_choices": 1,
            "structure_patterns": 1,
            "data_models": 1,
            "dashboard_patterns": 1,
            "kpi_patterns": 1,
            "business_workflows": 1,
        },
    },
    "deep": {
        "metadata_candidates_max": 10,
        "bucket_caps": {
            "official_docs": 4,
              "active_repositories": 2,
            "similar_solutions": 6,
            "issue_problem_sources": 2,
            "platform_choices": 2,
            "structure_patterns": 2,
            "data_models": 2,
            "dashboard_patterns": 2,
            "kpi_patterns": 2,
            "business_workflows": 2,
        },
    },
}

active_limits = mode_limits.get(mode, mode_limits["quick"])
bucket_counts = {}

def add_source(kind, title, url, why_relevant, confidence, source_bucket, notes, source_role="", source_kind=""):
    if mode == "none":
        return None
    if url in source_refs:
        return source_refs[url]
    if len(sources) >= active_limits["metadata_candidates_max"]:
        return None
    cap = active_limits["bucket_caps"].get(source_bucket, 1 if mode == "quick" else 2)
    if bucket_counts.get(source_bucket, 0) >= cap:
        return None

    ref = f"src-{len(source_refs) + 1}"
    source_refs[url] = ref
    bucket_counts[source_bucket] = bucket_counts.get(source_bucket, 0) + 1
    sources.append(
        {
            "kind": kind,
            "title": title,
            "url": url,
            "why_relevant": why_relevant,
            "confidence": confidence,
            "source_bucket": source_bucket,
            "notes": notes,
            "source_role": source_role,
            "source_kind": source_kind,
        }
    )
    provenance_entries.append(
        {
            "ref": ref,
            "origin_type": "source",
            "path_or_url": url,
            "label": title,
            "used_for": ["sources", "findings"],
        }
    )
    return ref


def ensure_source_ref(url, title):
    url = str(url or "").strip()
    title = str(title or url or "").strip()
    if not url:
        return ""
    if url in source_refs:
        return source_refs[url]
    ref = f"src-{len(source_refs) + 1}"
    source_refs[url] = ref
    provenance_entries.append(
        {
            "ref": ref,
            "origin_type": "source",
            "path_or_url": url,
            "label": title or url,
            "used_for": ["sources", "findings"],
        }
    )
    return ref


