    "entries": provenance_entries,
}
provenance_json.write_text(json.dumps(provenance_payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")

research_lines = [
    "# Research Summary",
    "",
    "## Topic",
    topic,
    "",
    "## Project type",
    project_type,
    "",
    "## Research mode",
    mode,
    f"- reason: {mode_reason}",
    "",
    "## Existing local context",
]
for item in local_memory_summary:
    research_lines.append(f"- {item}")

research_lines += [
    "",
    "## Search buckets",
]
for item in search_targets:
    research_lines.append(f"- {item}")

research_lines += [
    "",
    "## Suggested search queries",
]
for bucket, queries in query_sets.items():
    research_lines.append(f"### {bucket}")
    for q in queries:
        research_lines.append(f"- {q}")
    research_lines.append("")

research_lines += [
    "## Curated sources",
]
if sources:
    for src in sources:
        research_lines.append(f"- [{src['source_bucket']}] {src['title']} — {src['url']}")
        research_lines.append(f"  - why: {src['why_relevant']}")
        research_lines.append(f"  - notes: {src['notes']}")
else:
    research_lines.append("- none captured by curated adapters in this run")

research_lines += [
    "",
    "## Structured findings emitted",
    f"- findings_jsonl: {findings_jsonl}",
    f"- provenance_json: {provenance_json}",
    "",
    "## Recurring risks / patterns",
]
for item in uniq(risk_seeds):
    research_lines.append(f"- {item}")

research_lines += [
    "",
    "## Recommended starting approach",
]
for item in uniq(starting_approach):
    research_lines.append(f"- {item}")

research_lines += [
    "",
    "## What not to do",
]
for item in anti_patterns:
    research_lines.append(f"- {item}")

research_lines += [
    "",
    "## Open questions",
]
for item in open_questions:
    research_lines.append(f"- {item}")

research_md.write_text("\n".join(research_lines).rstrip() + "\n", encoding="utf-8")

print(f"wrote: {context_json}")
print(f"wrote: {sources_json}")
print(f"wrote: {findings_jsonl}")
print(f"wrote: {provenance_json}")
print(f"wrote: {research_md}")
PY2


# STEP17_INLINE_FETCH_EXTRACTION_V1
run_fetch_extraction_step17() {
  local artifact_dir="$1"
  local helper="/home/agent/bin/project-research-fetch-extract-step29.py"
  [[ -n "${artifact_dir:-}" ]] || return 0
  [[ -d "$artifact_dir" ]] || return 0
  [[ -x "$helper" ]] || return 0
  python3 "$helper" "$artifact_dir" >/dev/null 2>&1 || true
}

python3 - "$CONTEXT_JSON" "$SOURCES_JSON" "$FINDINGS_JSONL" "$PROVENANCE_JSON" "$QUALITY_REPORT_JSON" "$RUN_MANIFEST_JSON" "$RUNNER_VERSION" "$SKILL_NAME" "$SKILL_VERSION" "$TOPIC" "$PROMPT" "$ARTIFACT_DIR" "$STARTED_AT" <<'PY3'
from pathlib import Path
from datetime import datetime
import json
import sys

context_path = Path(sys.argv[1])
sources_path = Path(sys.argv[2])
findings_path = Path(sys.argv[3])
provenance_path = Path(sys.argv[4])
quality_path = Path(sys.argv[5])
manifest_path = Path(sys.argv[6])
runner_version = sys.argv[7]
skill_name = sys.argv[8]
skill_version = sys.argv[9]
topic = sys.argv[10]
prompt = sys.argv[11]
artifact_dir = sys.argv[12]
started_at = sys.argv[13]
finished_at = datetime.now().astimezone().isoformat()

context = json.loads(context_path.read_text(encoding="utf-8"))
sources_payload = json.loads(sources_path.read_text(encoding="utf-8"))
provenance_payload = json.loads(provenance_path.read_text(encoding="utf-8"))

search_targets = context.get("search_targets", [])
query_sets = context.get("query_sets", {})
local_memory_summary = context.get("local_memory_summary", [])
starting_approach = context.get("starting_approach", [])
anti_patterns = context.get("anti_patterns", [])

passed_gates = []
failed_gates = []
warnings = []
notes = []

if all(target in query_sets for target in search_targets):
    passed_gates.append("search_targets_have_query_sets")
else:
    failed_gates.append("search_targets_have_query_sets")

boilerplate_markers = ["topic workspace exists", "prior outputs may exist"]
boilerplate_hits = 0
for item in local_memory_summary:
    low = item.lower()
    if any(marker in low for marker in boilerplate_markers):
        boilerplate_hits += 1

if len(local_memory_summary) == 0:
    failed_gates.append("no_memory_boilerplate_dominance")
    warnings.append("local_memory_summary is empty")
elif boilerplate_hits < len(local_memory_summary):
    passed_gates.append("no_memory_boilerplate_dominance")
else:
    failed_gates.append("no_memory_boilerplate_dominance")
    warnings.append("local_memory_summary is mostly boilerplate")

if starting_approach and len(starting_approach) >= 3:
    passed_gates.append("starting_approach_not_generic")
else:
    failed_gates.append("starting_approach_not_generic")

if anti_patterns:
    passed_gates.append("anti_patterns_present")
else:
    failed_gates.append("anti_patterns_present")

findings = []
if findings_path.exists():
    for line in findings_path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if line:
            findings.append(json.loads(line))

prov_refs = {entry.get("ref") for entry in provenance_payload.get("entries", [])}
findings_have_refs = bool(findings) and all(item.get("provenance", {}).get("origin_ref") in prov_refs for item in findings)

if findings and provenance_payload.get("entries") and findings_have_refs:
    passed_gates.append("provenance_present_for_findings")
else:
    failed_gates.append("provenance_present_for_findings")
    warnings.append("findings/provenance linkage is incomplete")

source_count = len(sources_payload.get("sources", []))
if source_count == 0:
    if context.get("mode") in ("quick", "deep"):
        notes.append("no curated adapter matched the prompt; sources list remains empty")
    else:
        notes.append("sources list is empty in planning-only mode")
else:
    notes.append(f"curated sources captured: {source_count}")

status = "ok" if not failed_gates else "warning"

quality_report = {
    "topic": topic,
    "mode": context.get("mode"),
    "status": status,
    "passed_gates": passed_gates,
    "failed_gates": failed_gates,
    "warnings": warnings,
    "notes": notes,
}
quality_path.write_text(json.dumps(quality_report, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")

manifest = {
    "skill_name": skill_name,
    "skill_version": skill_version,
    "topic": topic,
    "mode": context.get("mode"),
    "mode_reason": context.get("mode_reason"),
    "execution_mode": context.get("execution_mode"),
    "execution_mode_reason": context.get("execution_mode_reason"),
    "model_access_layer": context.get("model_access_layer"),
    "human_in_loop": context.get("human_in_loop"),
    "requires_api_key": context.get("requires_api_key"),
    "supports_background_automation": context.get("supports_background_automation"),
    "started_at": started_at,
    "finished_at": finished_at,
    "runner_version": runner_version,
    "initial_prompt": prompt,
    "project_type": context.get("project_type"),
    "detected_classes": context.get("detected_classes"),
    "artifact_dir": artifact_dir,
    "artifacts": [
        str(context_path),
        str(Path(artifact_dir) / "precheck.txt"),
        str(Path(artifact_dir) / "sources.json"),
        str(findings_path),
        str(provenance_path),
        str(quality_path),
        str(manifest_path),
        str(Path(artifact_dir) / "RESEARCH.md"),
    ],
    "quality_gates": sorted(set(passed_gates + failed_gates)),
    "status": status,
}
manifest_path.write_text(json.dumps(manifest, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")

print(f"wrote: {quality_path}")
print(f"wrote: {manifest_path}")
PY3

run_fetch_extraction_step17 "$ARTIFACT_DIR"

ln -sfn "$ARTIFACT_DIR" "$ARTIFACTS_ROOT/latest"

