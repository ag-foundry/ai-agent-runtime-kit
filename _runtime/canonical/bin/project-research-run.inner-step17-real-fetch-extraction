    def adapter_match_score(adapter):
        hits = [term for term in adapter["match_terms"] if term in text]
        if not hits:
            return None
        first_pos = min(text.index(term) for term in hits)
        hit_count = len(hits)
        specificity = max(len(term) for term in hits)
        return (first_pos, -hit_count, -specificity)

    matched_adapters = []
    for adapter in adapter_catalog:
        score = adapter_match_score(adapter)
        if score is None:
            continue
        item = dict(adapter)
        item["_match_score"] = score
        matched_adapters.append(item)

    matched_adapters.sort(key=lambda x: x["_match_score"])

    max_source_slots = max((len(adapter["sources"]) for adapter in matched_adapters), default=0)

    for src_idx in range(max_source_slots):
        for adapter in matched_adapters:
            if src_idx >= len(adapter["sources"]):
                continue
            item = adapter["sources"][src_idx]
            add_source(
                kind=item["kind"],
                title=item["title"],
                url=item["url"],
                why_relevant=item["why_relevant"],
                confidence=item["confidence"],
                source_bucket=item["source_bucket"],
                notes=item["notes"],
            )



# STEP32_SOURCES_WRITER_DIVERSITY_V2
from urllib.parse import urlparse

def _infer_source_role_for_sources(kind, source_bucket, url):
    kind = str(kind or "").strip().lower()
    bucket = str(source_bucket or "").strip().lower()
    parsed = urlparse(str(url or ""))
    host = parsed.netloc.lower()
    low_path = parsed.path.lower()

    if kind == "official_repo":
        return "official_repo"
    if kind == "official_doc":
        return "official_docs"
    if kind == "issue_problem":
        return "issue_problem"
    if kind == "community_doc":
        if bucket == "regional_community":
            return "regional_community"
        return "practical_community"

    if bucket == "official_docs":
        return "official_docs"
    if bucket == "active_repositories":
        return "official_repo"
    if bucket == "issue_problem_sources":
        return "issue_problem"
    if bucket == "regional_community":
        return "regional_community"
    if bucket == "similar_solutions":
        return "practical_community"

    if host == "github.com":
        if "/issues/" in low_path or "/discussions/" in low_path:
            return "issue_problem"

    return "generic_reference"


def _canonicalize_source_entry(entry):
    row = dict(entry or {})
    url = str(row.get("url") or "").strip()
    title = row.get("title") or row.get("source_title") or url

    explicit_role = str(
        row.get("source_role")
        or row.get("role")
        or row.get("best_role")
        or ""
    ).strip().lower()

    bucket = str(row.get("source_bucket") or "").strip().lower()
    kind = str(row.get("kind") or row.get("source_kind") or "").strip().lower()

    inferred_role = _infer_source_role_for_sources(kind, bucket, url)
    role = explicit_role or inferred_role

    if role == "official_repo" or kind == "official_repo" or (not explicit_role and bucket == "active_repositories"):
        role = "official_repo"
        bucket = "active_repositories"
        kind = "official_repo"
    elif role == "official_docs" or kind == "official_doc" or (not explicit_role and bucket == "official_docs"):
        role = "official_docs"
        bucket = "official_docs"
        kind = "official_doc"
    elif role == "issue_problem" or kind == "issue_problem" or (not explicit_role and bucket == "issue_problem_sources"):
        role = "issue_problem"
        bucket = "issue_problem_sources"
        kind = "issue_problem"
    elif role == "regional_community" or (not explicit_role and bucket == "regional_community"):
        role = "regional_community"
        bucket = "regional_community"
        kind = "community_doc"
    elif role == "practical_community" or kind in ("community_doc", "active_repository") or (not explicit_role and bucket == "similar_solutions"):
        role = "practical_community"
        bucket = "similar_solutions"
        kind = "community_doc"
    else:
        if not bucket:
            bucket = "similar_solutions"
        if not kind:
            kind = "external_search"

    row["title"] = title
    row["source_role"] = role
    row["source_bucket"] = bucket
    row["kind"] = kind
    return row

def _bucket_quotas_for_sources(mode_name):
    mode_name = str(mode_name or "").strip().lower()
    if mode_name == "deep":
        return {
            "official_docs": 3,
            "active_repositories": 2,
            "similar_solutions": 3,
            "issue_problem_sources": 2,
            "regional_community": 1,
        }
    return {
        "official_docs": 2,
        "active_repositories": 1,
        "similar_solutions": 2,
        "issue_problem_sources": 1,
        "regional_community": 1,
    }


def _merge_sources_with_rerank(curated_sources, rerank_plan, mode_name):
    quotas = _bucket_quotas_for_sources(mode_name)
    selected = []
    selected_index_by_url = {}
    bucket_counts = {k: 0 for k in quotas}

    def _bucket(item):
        return str(item.get("source_bucket") or "").strip().lower()

    def _role_rank(item):
        role = str(item.get("source_role") or "").strip().lower()
        table = {
            "official_repo": 50,
            "official_docs": 40,
            "issue_problem": 35,
            "practical_community": 25,
            "regional_community": 24,
            "generic_reference": 0,
        }
        return table.get(role, 0)

    def _kind_rank(item):
        kind = str(item.get("kind") or "").strip().lower()
        table = {
            "official_repo": 8,
            "official_doc": 6,
            "issue_problem": 5,
            "community_doc": 4,
            "active_repository": 3,
        }
        return table.get(kind, 0)

    def _confidence_rank(item):
        conf = str(item.get("confidence") or "").strip().lower()
        table = {"high": 3, "medium": 2, "low": 1}
        return table.get(conf, 0)

    def _note_rank(item):
        notes = str(item.get("notes") or "").strip().lower()
        score = 0
        if "curated official repo adapter" in notes:
            score += 12
        elif "curated official adapter" in notes:
            score += 10
        elif "curated github adapter" in notes:
            score += 8
        elif "curated" in notes:
            score += 6
        if "promoted from rerank_plan.ranked_targets" in notes:
            score -= 2
        if "promoted from rerank_plan.top_chunks" in notes:
            score -= 3
        return score

    def _strength(item):
        return (
            _role_rank(item)
            + _kind_rank(item)
            + _confidence_rank(item)
            + _note_rank(item)
        )

    def _inc_bucket(bucket):
        if bucket in bucket_counts:
            bucket_counts[bucket] += 1

    def _dec_bucket(bucket):
        if bucket in bucket_counts:
            bucket_counts[bucket] = max(0, bucket_counts[bucket] - 1)

    def _replace_index(idx, item):
        old = selected[idx]
        old_url = str(old.get("url") or "").strip()
        new_url = str(item.get("url") or "").strip()
        old_bucket = _bucket(old)
        new_bucket = _bucket(item)

        if old_url in selected_index_by_url:
            del selected_index_by_url[old_url]
        _dec_bucket(old_bucket)

        selected[idx] = item
        selected_index_by_url[new_url] = idx
        _inc_bucket(new_bucket)

    def _find_weakest_index_for_bucket(bucket):
        weakest_idx = None
        weakest_score = None
        for idx, row in enumerate(selected):
            if _bucket(row) != bucket:
                continue
            score = _strength(row)
            if weakest_idx is None or score < weakest_score:
                weakest_idx = idx
                weakest_score = score
        return weakest_idx

    def try_add(row, allow_bucket_replace=False):
        item = _canonicalize_source_entry(row)
        url = str(item.get("url") or "").strip()
        if not url:
            return False

        bucket = _bucket(item)
        new_score = _strength(item)

        if url in selected_index_by_url:
            idx = selected_index_by_url[url]
            existing = selected[idx]
            if new_score <= _strength(existing):
                return False
            existing_bucket = _bucket(existing)
            if bucket != existing_bucket and bucket in quotas and bucket_counts[bucket] >= quotas[bucket]:
                if not allow_bucket_replace:
                    return False
                weakest_idx = _find_weakest_index_for_bucket(bucket)
                if weakest_idx is None:
                    return False
                weakest = selected[weakest_idx]
                if new_score <= _strength(weakest):
                    return False
                _replace_index(weakest_idx, item)
                return True
            _replace_index(idx, item)
            return True

        if bucket in quotas and bucket_counts[bucket] >= quotas[bucket]:
            if not allow_bucket_replace:
                return False
            weakest_idx = _find_weakest_index_for_bucket(bucket)
            if weakest_idx is None:
                return False
            weakest = selected[weakest_idx]
            if new_score <= _strength(weakest):
                return False
            _replace_index(weakest_idx, item)
            return True

        idx = len(selected)
        selected.append(item)
        selected_index_by_url[url] = idx
        _inc_bucket(bucket)
        return True

    ranked_targets = []
    top_chunks = []
    if isinstance(rerank_plan, dict):
        ranked_targets = rerank_plan.get("ranked_targets") or []
        top_chunks = rerank_plan.get("top_chunks") or []

    preferred_order = (
        "official_docs",
        "active_repositories",
        "issue_problem_sources",
        "similar_solutions",
        "regional_community",
    )

    by_bucket = {k: [] for k in preferred_order}

    for row in ranked_targets:
        item = _canonicalize_source_entry({
            "url": row.get("url"),
            "title": row.get("title") or row.get("source_title"),
            "source_title": row.get("source_title") or row.get("title"),
            "source_role": row.get("source_role"),
            "source_bucket": row.get("source_bucket"),
            "kind": row.get("kind"),
            "why_relevant": row.get("why_extract") or "promoted from rerank target",
            "confidence": "medium",
            "notes": "promoted from rerank_plan.ranked_targets",
        })
        bucket = _bucket(item)
        if bucket in by_bucket:
            by_bucket[bucket].append(item)

    for row in top_chunks:
        item = _canonicalize_source_entry({
            "url": row.get("source_url") or row.get("url"),
            "title": row.get("title") or row.get("source_title"),
            "source_title": row.get("source_title") or row.get("title"),
            "source_role": row.get("source_role"),
            "source_bucket": row.get("source_bucket"),
            "kind": row.get("kind"),
            "why_relevant": row.get("why_extract") or "promoted from rerank top chunk",
            "confidence": "medium",
            "notes": "promoted from rerank_plan.top_chunks",
        })
        bucket = _bucket(item)
        if bucket in by_bucket:
            by_bucket[bucket].append(item)

    # 1) seed from rerank
    for bucket in preferred_order:
        for item in by_bucket[bucket]:
            try_add(item, allow_bucket_replace=False)

    # 2) curated backfill may replace weaker bucket entries and wrong duplicate-role URLs
    for row in curated_sources or []:
        try_add(row, allow_bucket_replace=True)

    # 3) final rerank fill only for remaining free slots
    for bucket in preferred_order:
        for item in by_bucket[bucket]:
            try_add(item, allow_bucket_replace=False)

    limit = sum(quotas.values())
    return selected[:limit]


sources = _merge_sources_with_rerank(sources, _PR_LAST_RERANK_PLAN, mode)

