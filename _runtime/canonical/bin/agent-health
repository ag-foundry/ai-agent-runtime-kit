#!/usr/bin/env bash
set -euo pipefail

TOPIC="${1:-core}"
MODE="${2:-quick}"   # quick | full

TS="$(date +%F-%H%M%S)"
BASE="$HOME/agents/$TOPIC"
OUTDIR="$BASE/artifacts/healthcheck/$TS"
mkdir -p "$OUTDIR"

REPORT="$OUTDIR/report.md"
touch "$REPORT"

say() { printf "%s\n" "$*" | tee -a "$REPORT" >/dev/null; }
cmd() {
  local title="$1"; shift
  say ""
  say "## $title"
  say "\`\`\`"
  ( "$@" ) 2>&1 | tee -a "$REPORT" >/dev/null || { say "[FAILED rc=$?]"; }
  say "\`\`\`"
}

check_script() {
  local p="$1"
  local sh
  sh="$(head -n 1 "$p" 2>/dev/null || true)"

  if [[ "$sh" == \#\!*bash* || "$sh" == \#\!*sh* ]]; then
    bash -n "$p"; return $?
  fi
  if [[ "$sh" == \#\!*python* ]]; then
    python3 -m py_compile "$p"; return $?
  fi
  if [[ "$sh" == \#\!*node* ]]; then
    node --check "$p"; return $?
  fi

  local ft
  ft="$(file -b "$p" 2>/dev/null || true)"
  if echo "$ft" | grep -qi 'python'; then python3 -m py_compile "$p"; return $?; fi
  if echo "$ft" | grep -qi 'shell script'; then bash -n "$p"; return $?; fi

  test -r "$p" && test -x "$p"
}

say "# Healthcheck: topic=$TOPIC mode=$MODE time=$TS"
say "- base: $BASE"
say "- out:  $OUTDIR"

cmd "1) Paths" bash -lc "ls -la '$HOME/bin' | head -n 60; echo; ls -la '$BASE'"

cmd "2) Codex rules link" bash -lc "ls -la '$HOME/.codex/AGENTS.md' || true; readlink -f '$HOME/.codex/AGENTS.md' || true"

cmd "3) Profiles" bash -lc "ls -la '$HOME/agents/_shared/profiles' || true"

cmd "4) Topics skeleton check" bash -lc '
for t in vuplus epg vpn router minipc mcp accounting skins-plugins bonding; do
  echo "=== $t ==="
  test -d "$HOME/agents/$t" && echo "dir: OK" || echo "dir: MISSING"
  test -f "$HOME/agents/$t/PROFILE.md" && head -n 3 "$HOME/agents/$t/PROFILE.md" || echo "PROFILE.md: MISSING"
done
'

say ""
say "## 5) Script syntax (smart by shebang)"
say "\`\`\`"
for f in agent-exec agent-topic agent-run-report agent-usage apply-fix codex-jsonl-last graphmem graphmem-extract graphmem-recall memory agent-health; do
  p="$HOME/bin/$f"
  if [[ -f "$p" ]]; then
    if check_script "$p"; then
      echo "OK: $p"
    else
      echo "BAD: $p"
    fi
  else
    echo "MISSING: $p"
  fi
done | tee -a "$REPORT" >/dev/null
say "\`\`\`"

cmd "6) Memory stack docker (best-effort)" bash -lc '
if command -v docker >/dev/null 2>&1; then
  echo "docker: OK"
  docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" | sed -n "1,20p"
  echo
  echo "ss listeners (local):"
  ss -lntp | sed -n "1,45p"
else
  echo "docker: NOT FOUND"
fi
'

cmd "7) RAG recall smoke (best-effort)" bash -lc "
memory snapshot --topic '$TOPIC' --query 'порты ssh xray 3x-ui fallback' --out '$OUTDIR/rag_recall.md' || true
ls -la '$OUTDIR/rag_recall.md' && sed -n '1,140p' '$OUTDIR/rag_recall.md'
"

cmd "8) Graph recall smoke (best-effort)" bash -lc "
if command -v docker >/dev/null 2>&1; then
  AUTH_LINE=\"\$(docker inspect ai-neo4j --format '{{range .Config.Env}}{{println .}}{{end}}' 2>/dev/null | grep '^NEO4J_AUTH=' || true)\"
  if [[ -n \"\$AUTH_LINE\" ]]; then
    AUTH=\"\${AUTH_LINE#NEO4J_AUTH=}\"
    export NEO4J_URI='bolt://127.0.0.1:7687'
    export NEO4J_USER=\"\${AUTH%%/*}\"
    export NEO4J_PASS=\"\${AUTH#*/}\"
    '$HOME/bin/graphmem-recall' 'ports xray 3x-ui fallback ssh' > '$OUTDIR/graph_recall.md' || true
    ls -la '$OUTDIR/graph_recall.md' && sed -n '1,180p' '$OUTDIR/graph_recall.md'
  else
    echo 'Neo4j auth not found via docker inspect'
  fi
else
  echo 'docker not available'
fi
"

if [[ "$MODE" == "full" ]]; then
  cmd "9) agent-exec end-to-end (COSTS TOKENS)" bash -lc "
agent-exec '$TOPIC' 'Какие порты у SSH/Xray/3X-UI и куда fallback?' || true
ls -t '$BASE/runs' | head -n 12
"
else
  say ""
  say "## 9) agent-exec end-to-end"
  say "_skipped (mode=quick)_"
fi

say ""
say "## DONE"
say "- report: $REPORT"
echo "OK: wrote $REPORT"